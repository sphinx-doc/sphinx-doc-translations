#: ../../sphinx/doc/extdev/eventapi.rst:4
msgid "Event Manager API"
msgstr "事件管理器API"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager:1
msgid "Event manager for Sphinx."
msgstr "Sphinx的活动管理器"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.add:1
msgid "Register a custom Sphinx event called *name*."
msgstr "注册一个名为 *name* 的自定义Sphinx事件。"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.add:3
msgid "This is needed to be able to emit the event."
msgstr "需要这样做才能发出该事件。"

#: ../../sphinx/doc/extdev/eventapi.rst:0
msgid "Parameters"
msgstr "参数"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.add:5
msgid "The name of the event."
msgstr "事件的名称。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:1
msgid "Connect a handler to specific event."
msgstr "将处理程序连接到特定事件。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:3
msgid "Register *callback* to be called when the *name* event is emitted."
msgstr "注册 *callback* 以在发出 *name* 事件时调用。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:5
msgid ""
"See :ref:`event callbacks <events>` for details on available core events and"
" the arguments of their corresponding callback functions."
msgstr "有关可用核心事件及其相应回调函数参数的详细信息，请参见 :ref:`event callbacks <events>` 。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:8
msgid "The name of the target event."
msgstr "目标事件的名称。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:10
msgid "Callback function for the event."
msgstr "事件的回调函数。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:12
msgid ""
"The priority of the callback. The callbacks will be invoked in ascending "
"order of *priority*."
msgstr "回调的优先级。回调将按 *priority* 的升序调用。"

#: ../../sphinx/doc/extdev/eventapi.rst:0
msgid "Returns"
msgstr "返回"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:15
msgid "A listener ID, for use with the :meth:`disconnect` method."
msgstr "监听器ID，用于 :meth:`disconnect` 方法。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.connect:20
msgid "Support *priority*"
msgstr "支持 *优先级*"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.disconnect:1
msgid "Disconnect the handler given by *listener_id*."
msgstr "断开由 *listener_id* 给出的处理程序。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.disconnect:3
msgid "A listener_id previously returned by :meth:`connect`."
msgstr "先前由 :meth:`connect` 返回的 listener_id。"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.emit:1
msgid "Emit a Sphinx event."
msgstr "发射Sphinx事件。"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.emit:3
msgid ""
"This emits the *name* event and passes *args* to the handler functions. "
"Return the return values of all handlers as a list. Do not emit core Sphinx "
"events in extensions!"
msgstr ""
"这会发出 *name* 事件并将 *args* 传递给处理程序函数。将所有处理程序的返回值作为列表返回。不要在扩展中发出核心Sphinx事件！"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.emit:7
#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit_firstresult:6
msgid "The name of the event that will be emitted."
msgstr "将要发出的事件的名称。"

#: ../../sphinx/sphinx/events.pydocstring of sphinx.events.EventManager.emit:9
#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit_firstresult:8
msgid "The arguments for the event, to be passed to the handler functions."
msgstr "传递给处理程序函数的事件参数。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit:11 ../../sphinx/sphinx/events.pydocstring
#: of sphinx.events.EventManager.emit_firstresult:10
msgid "The list of exceptions that are allowed in the handlers."
msgstr "处理程序中允许的异常列表。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit:16 ../../sphinx/sphinx/events.pydocstring
#: of sphinx.events.EventManager.emit_firstresult:16
msgid "Added *allowed_exceptions* to specify path-through exceptions"
msgstr "添加了*allowed_exceptions*来指定路径穿越异常"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit_firstresult:1
msgid "Emit a Sphinx event and return the first result."
msgstr "发出Sphinx事件并返回第一个结果。"

#: ../../sphinx/sphinx/events.pydocstring of
#: sphinx.events.EventManager.emit_firstresult:3
msgid ""
"This emits the *name* event and passes *args* to the handler functions. The "
"first non-None result is returned."
msgstr "这会发出 *name* 事件并将 *args* 传递给处理程序函数。返回第一个非None结果。"
